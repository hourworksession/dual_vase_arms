<?xml version="1.0"?>
<robot name="adrs_turntable">
  <link name="base">
    <visual>
      <geometry>
        <cylinder length="0.10" radius="0.32"/>
      </geometry>
      <material name="grey">
        <color rgba="0.4 0.4 0.4 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.10" radius="0.32"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="20"/>
      <inertia ixx="0.5" iyy="0.5" izz="1.0" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <link name="disc">
    <visual>
      <origin xyz="0 0 0.053"/>
      <geometry>
        <cylinder length="0.006" radius="0.30"/>
      </geometry>
      <material name="acrylic">
        <color rgba="0.85 0.95 1.0 0.55"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.053"/>
      <geometry>
        <cylinder length="0.006" radius="0.30"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="2.5"/>
      <inertia ixx="0.05" iyy="0.05" izz="0.10" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="rotary_axis" type="continuous">
    <parent link="base"/>
    <child link="disc"/>
    <axis xyz="0 0 1"/>
    <origin xyz="0 0 0.05"/>
  </joint>
</robot>
